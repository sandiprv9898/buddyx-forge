<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{PROJECT_TITLE} — Agent Dashboard</title>
<style>
:root{--bg:#0f172a;--surface:#1e293b;--border:#334155;--text:#e2e8f0;--muted:#94a3b8;--accent:#38bdf8;--success:#4ade80;--warning:#fbbf24;--danger:#f87171}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.6}
.header{background:var(--surface);padding:20px 32px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.header h1{font-size:20px;font-weight:700}.header .meta{color:var(--muted);font-size:13px}
.content{max-width:1400px;margin:0 auto;padding:24px 32px}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:32px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;text-align:center}
.card .value{font-size:36px;font-weight:700;color:var(--accent)}.card .label{font-size:13px;color:var(--muted);margin-top:4px}
.card.pass .value{color:var(--success)}.card.fail .value{color:var(--danger)}.card.warn .value{color:var(--warning)}
h2{margin:24px 0 12px;color:var(--accent);font-size:18px}
table{width:100%;border-collapse:collapse;margin:12px 0}
th{background:var(--surface);padding:10px 14px;text-align:left;font-size:13px;font-weight:600;color:var(--muted);border-bottom:2px solid var(--border)}
td{padding:10px 14px;border-bottom:1px solid var(--border);font-size:14px}
tr:hover td{background:rgba(56,189,248,.05)}
.badge{display:inline-block;padding:2px 10px;border-radius:12px;font-size:12px;font-weight:600}
.badge-pass{background:rgba(74,222,128,.15);color:var(--success)}.badge-fail{background:rgba(248,113,113,.15);color:var(--danger)}
.timeline{margin:16px 0}.tl-item{padding:8px 16px;border-left:3px solid var(--border);margin-left:12px;font-size:14px}
.tl-item.start{border-color:var(--accent)}.tl-item.stop{border-color:var(--success)}.tl-item.fail{border-color:var(--danger)}
.tl-time{color:var(--muted);font-size:12px}
.refresh{padding:8px 20px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text);cursor:pointer;font-size:14px}
.refresh:hover{background:var(--accent);color:var(--bg)}
.empty{text-align:center;padding:40px;color:var(--muted)}
</style>
</head>
<body>
<div class="header">
<div><h1>{PROJECT_TITLE} Agent Dashboard</h1><div class="meta">Data from .claude/dashboard/events.jsonl</div></div>
<button class="refresh" onclick="location.reload()">Refresh</button>
</div>
<div class="content">
<div class="grid" id="summary-cards"></div>
<h2>Agent Performance</h2>
<table id="agent-table"><thead><tr><th>Agent</th><th>Sessions</th><th>Avg Duration</th><th>Files Changed</th><th>Pass Rate</th><th>Last Run</th></tr></thead><tbody></tbody></table>
<h2>Recent Activity</h2>
<div class="timeline" id="timeline"></div>
</div>
<script>
const EVENTS_DATA = [];
function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML}
function formatDuration(s){if(s<60)return s+'s';if(s<3600)return Math.floor(s/60)+'m '+s%60+'s';return Math.floor(s/3600)+'h '+Math.floor((s%3600)/60)+'m'}
function formatTime(t){try{return new Date(t).toLocaleString()}catch(e){return t}}

function render(){
  var events=EVENTS_DATA;
  if(!events.length){document.getElementById('summary-cards').innerHTML='<div class="empty" style="grid-column:1/-1">No agent sessions yet. Run an agent to see metrics here.</div>';return}
  var agents={},total=0,totalPass=0,totalFail=0,totalFiles=0,totalDuration=0;
  events.forEach(function(e){
    if(!e.agent)return;
    if(!agents[e.agent])agents[e.agent]={sessions:0,duration:0,files:0,pass:0,fail:0,last:''};
    var a=agents[e.agent];
    if(e.event==='STOP'){a.sessions++;total++;a.duration+=(e.duration_sec||0);totalDuration+=(e.duration_sec||0);a.files+=(e.files_changed||0);totalFiles+=(e.files_changed||0);a.last=e.time||''}
    if(e.event==='VALIDATE'){if(e.result==='PASS'){a.pass++;totalPass++}else{a.fail++;totalFail++}}
  });
  var cards=[
    {v:total,l:'Total Sessions',c:''},
    {v:totalPass,l:'Passed',c:'pass'},
    {v:totalFail,l:'Failed',c:'fail'},
    {v:totalFiles,l:'Files Changed',c:''},
    {v:formatDuration(Math.round(totalDuration/(total||1))),l:'Avg Duration',c:''},
    {v:Object.keys(agents).length,l:'Active Agents',c:''}
  ];
  document.getElementById('summary-cards').innerHTML=cards.map(function(c){return '<div class="card '+c.c+'"><div class="value">'+c.v+'</div><div class="label">'+esc(c.l)+'</div></div>'}).join('');
  var rows='';
  Object.keys(agents).sort().forEach(function(name){
    var a=agents[name];var rate=a.pass+a.fail>0?Math.round(a.pass/(a.pass+a.fail)*100):'-';
    rows+='<tr><td><b>'+esc(name)+'</b></td><td>'+a.sessions+'</td><td>'+formatDuration(Math.round(a.duration/(a.sessions||1)))+'</td><td>'+a.files+'</td><td>'+(rate==='-'?'-':'<span class="badge '+(rate>=80?'badge-pass':'badge-fail')+'">'+rate+'%</span>')+'</td><td>'+formatTime(a.last)+'</td></tr>'
  });
  document.querySelector('#agent-table tbody').innerHTML=rows;
  var recent=events.slice(-20).reverse();
  document.getElementById('timeline').innerHTML=recent.map(function(e){
    var cls=e.event==='START'?'start':(e.result==='FAIL'?'fail':'stop');
    return '<div class="tl-item '+cls+'"><span class="tl-time">'+formatTime(e.time)+'</span> <b>'+esc(e.agent||'?')+'</b> '+esc(e.event||'')+
      (e.duration_sec?' ('+formatDuration(e.duration_sec)+')':'')+
      (e.files_changed?' — '+e.files_changed+' files':'')+
      (e.result?' — '+e.result:'')+
      '</div>'
  }).join('');
}
document.addEventListener('DOMContentLoaded',render);
</script>
</body>
</html>

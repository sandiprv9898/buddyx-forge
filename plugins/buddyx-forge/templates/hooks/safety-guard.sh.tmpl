#!/bin/bash
# PreToolUse hook: Blocks truly dangerous commands.
# Generated by buddyx-forge.

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty' 2>/dev/null)

[ "$TOOL" = "Bash" ] || exit 0

COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null)
[ -z "$COMMAND" ] && exit 0

# Destructive file operations
if echo "$COMMAND" | grep -qE 'rm\s+(-[a-zA-Z]*f[a-zA-Z]*\s+)?/($|\s)'; then
  echo "BLOCKED: rm on root directory." >&2; exit 2
fi
if echo "$COMMAND" | grep -qE 'rm\s+-[a-zA-Z]*r[a-zA-Z]*f[a-zA-Z]*\s+/'; then
  echo "BLOCKED: recursive force delete on root path." >&2; exit 2
fi

# Destructive SQL
if echo "$COMMAND" | grep -qiE '\b(DROP\s+(TABLE|DATABASE|SCHEMA)|TRUNCATE\s+TABLE|DELETE\s+FROM\s+\w+\s*$|DELETE\s+FROM\s+\w+\s*;)'; then
  echo "BLOCKED: Destructive SQL detected." >&2; exit 2
fi

# Dangerous git
if echo "$COMMAND" | grep -qiE 'git\s+push\s+.*--force|git\s+push\s+-f\b'; then
  echo "BLOCKED: git push --force." >&2; exit 2
fi
if echo "$COMMAND" | grep -qiE '\-\-no-verify'; then
  echo "BLOCKED: --no-verify bypasses safety hooks." >&2; exit 2
fi

# Dangerous permissions
if echo "$COMMAND" | grep -qE 'chmod\s+777'; then
  echo "BLOCKED: chmod 777." >&2; exit 2
fi

# Dangerous system commands
if echo "$COMMAND" | grep -qE 'sudo\s+(rm|dd|mkfs|fdisk|shred)\b'; then
  echo "BLOCKED: Dangerous sudo operation." >&2; exit 2
fi
if echo "$COMMAND" | grep -qE 'mkfs\.|fdisk\s|>\s*/dev/sd'; then
  echo "BLOCKED: Disk formatting/overwrite." >&2; exit 2
fi

exit 0

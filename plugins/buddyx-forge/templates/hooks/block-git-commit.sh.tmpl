#!/bin/bash
# PreToolUse hook: Blocks git commit commands. User commits manually.
# Generated by buddyx-forge.

INPUT=$(cat)

if ! command -v jq &>/dev/null; then
  echo '{"error": "jq not available — blocking bash for safety"}' >&2
  exit 2
fi

COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty' 2>/dev/null)
[ -z "$COMMAND" ] && exit 0

if echo "$COMMAND" | grep -qiE '\bgit\s+(commit|push|merge|rebase)\b'; then
  echo "BLOCKED: Git commits are manual. Do not commit, push, merge, or rebase." >&2
  exit 2
fi

exit 0

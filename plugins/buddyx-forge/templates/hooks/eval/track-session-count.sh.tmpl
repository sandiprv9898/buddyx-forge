#!/bin/bash
# SubagentStop hook: Records duration and files changed.
# Generated by buddyx-forge.

INPUT=$(cat)
if ! command -v jq &>/dev/null; then
  exit 0
fi
AGENT_TYPE=$(echo "$INPUT" | jq -r '.agent_type // empty' 2>/dev/null)
AGENT_TYPE=$(echo "$AGENT_TYPE" | tr -cd 'a-zA-Z0-9-')
PROJECT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
DASHBOARD_DIR="${PROJECT_DIR}/.claude/dashboard"

if ! echo "$AGENT_TYPE" | grep -q "^{PROJECT_NAME}-"; then
  exit 0
fi

# Calculate duration
START_TIME=$(cat "/tmp/{PROJECT_NAME}-start-time-${AGENT_TYPE}" 2>/dev/null || echo "0")
END_TIME=$(date +%s)
DURATION=0
if [ "$START_TIME" != "0" ]; then
  DURATION=$((END_TIME - START_TIME))
fi

# Count changed files
PRE_FILES="/tmp/{PROJECT_NAME}-eval-pre-files-${AGENT_TYPE}"
CURRENT_COUNT=$(git -C "$PROJECT_DIR" diff --name-only 2>/dev/null | wc -l | tr -d ' ')
PRE_COUNT=0
if [ -f "$PRE_FILES" ]; then
  PRE_COUNT=$(wc -l < "$PRE_FILES" | tr -d ' ')
fi
FILES_CHANGED=$((CURRENT_COUNT - PRE_COUNT))
if [ $FILES_CHANGED -lt 0 ]; then FILES_CHANGED=0; fi

TIMESTAMP=$(date -Iseconds)
echo "{\"time\":\"${TIMESTAMP}\",\"agent\":\"${AGENT_TYPE}\",\"event\":\"STOP\",\"files_changed\":${FILES_CHANGED},\"duration_sec\":${DURATION}}" >> "${DASHBOARD_DIR}/events.jsonl"

cat > "${DASHBOARD_DIR}/live-status.json" <<EOF
{
  "current_agent": "${AGENT_TYPE}",
  "status": "COMPLETED",
  "files_changed": ${FILES_CHANGED},
  "duration_sec": ${DURATION},
  "last_updated": "${TIMESTAMP}"
}
EOF

exit 0

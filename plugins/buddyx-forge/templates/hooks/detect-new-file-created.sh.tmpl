#!/bin/bash
# PostToolUse hook: Checks if new file is in domain-map.
# Generated by buddyx-forge.

INPUT=$(cat)
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null)
PROJECT_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
DOMAIN_MAP="${PROJECT_DIR}/.claude/skills/{PROJECT_NAME}/context/domain-map.md"

# Only check PHP files in app/
echo "$FILE_PATH" | grep -qE "\.php$" || exit 0
echo "$FILE_PATH" | grep -qE "(^|/)app/" || exit 0

REL_PATH=$(echo "$FILE_PATH" | sed "s|${PROJECT_DIR}/||")

if [ -f "$DOMAIN_MAP" ]; then
  if ! grep -qF "$REL_PATH" "$DOMAIN_MAP" 2>/dev/null; then
    DIR_PATH=$(dirname "$REL_PATH")
    if ! grep -q "${DIR_PATH}/\*\*" "$DOMAIN_MAP" 2>/dev/null; then
      echo "WARNING: NEW FILE not in domain-map: ${REL_PATH}" >&2
      echo "   Run /buddyx-forge:scan or add manually to domain-map.md" >&2

      DASHBOARD_DIR="${PROJECT_DIR}/.claude/dashboard"
      mkdir -p "$DASHBOARD_DIR" 2>/dev/null
      echo "{\"time\":\"$(date -Iseconds)\",\"event\":\"NEW_FILE\",\"file\":\"${REL_PATH}\"}" >> "${DASHBOARD_DIR}/events.jsonl" 2>/dev/null
    fi
  fi
fi

exit 0
